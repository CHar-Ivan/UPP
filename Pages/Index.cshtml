@page
@model IndexModel
@{
    ViewData["Title"] = "Музейная база данных";
}

<div class="text-center my-4">
</div>

<form method="post" class="d-flex justify-content-center gap-3 mb-4">
    <button type="submit" name="action" value="addExhibit" class="btn btn-outline-primary">Добавить Экспонат</button>
    <button type="submit" name="action" value="addCountry" class="btn btn-outline-primary">Добавить Страну</button>
</form>

<h3 class="text-center mb-3">Текущие экспозиции музея</h3>
<table class="table table-bordered table-striped align-middle text-center">
    <thead class="table-dark">
        <tr>
            <th>Экспонат (Exhibit)</th>
            <th>Автор (Exhibitor)</th>
            <th>Дата размещения</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @if (Model.pr.Count == 0)
        {
            <tr>
                <td colspan="4" class="text-muted">На выставке пока нет экспонатов. Разместите их ниже.</td>
            </tr>
        }
        @foreach (var note in Model.pr)
        {
            <tr>
                <td>@note.Exhibit</td>
                <td>@note.Exhibitor</td>
                <td>@note.Date</td>
                <td>
                    <form method="post" asp-page-handler="Delete" asp-route-id="@note.Id" onsubmit="return confirm('Вы уверены, что хотите убрать этот экспонат с выставки?');" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-danger">Убрать с выставки</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<hr class="my-5" />

<div class="row justify-content-center gap-4">
    <div class="col-md-5 border p-4 bg-light rounded shadow-sm">
        <h4 class="text-center mb-3">Зарегистрировать на выставку</h4>
        <form method="post">
            <input type="hidden" name="action" value="addNote" />

            <div class="form-group mb-3">
                <label for="Exhibitor" class="form-label fw-bold">Выберите автора:</label>
                <select name="selectedExhibitorId" id="Exhibitor" class="form-select" required>
                    <option value="">-- Выберите автора --</option>
                    @foreach (var auth in Model.exhibitors)
                    {
                        <option value="@auth.Id">@auth.FIO (@auth.Style)</option>
                    }
                </select>
            </div>

            <div class="form-group mb-3">
                <label for="Exhibit" class="form-label fw-bold">Выберите экспонат:</label>
                <select name="selectedExhibitId" id="Exhibit" class="form-select" required>
                    <option value="">-- Выберите экспонат --</option>
                    @foreach (var ex in Model.exhibits)
                    {
                        <option value="@ex.Id">@ex.Name</option>
                    }
                </select>
            </div>

            <button type="submit" class="btn btn-success w-100">Разместить на выставке</button>
        </form>
    </div>

    <div class="col-md-5 border p-4 bg-warning bg-opacity-10 rounded shadow-sm" id="editFormContainer" style="display:none;">
        <h4 class="text-center text-warning-emphasis mb-3">Редактировать экспонат</h4>
        <form method="post" asp-page-handler="EditExhibit">
            <input type="hidden" id="EditId" asp-for="EditingExhibit.Id" />

            <div class="form-group mb-3">
                <label class="form-label fw-bold">Название:</label>
                <input type="text" id="EditName" asp-for="EditingExhibit.Name" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-bold">Материал:</label>
                <input type="text" id="EditMaterial" asp-for="EditingExhibit.Material" class="form-control" required />
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-bold">Страна происхождения:</label>
                <select id="EditCountry" asp-for="EditingExhibit.Country_Id" class="form-select" required>
                    @foreach (var c in Model.countries)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-warning w-100 fw-bold">Сохранить изменения</button>
                <button type="button" onclick="closeEditForm()" class="btn btn-secondary">Отмена</button>
            </div>
        </form>
    </div>
</div>

<hr class="my-5" />

<h3 class="text-center mb-3">Все экспонаты фонда музея</h3>
<table class="table table-sm table-striped table-bordered text-center align-middle">
    <thead class="table-secondary">
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Материал</th>
            <th>Действие</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model.exhibits)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Material</td>
                <td>
                    <button type="button" class="btn btn-sm btn-outline-warning"
                            onclick="openEditForm('@item.Id', '@item.Name', '@item.Material', '@item.Country_Id')">
                        Редактировать
                    </button>
                </td>
            </tr>
        }
    </tbody>
</table>

<script>
    function openEditForm(id, name, material, countryId) {
        document.getElementById('editFormContainer').style.display = 'block';
        document.getElementById('EditId').value = id;
        document.getElementById('EditName').value = name;
        document.getElementById('EditMaterial').value = material;
        document.getElementById('EditCountry').value = countryId;
        window.scrollTo({ top: document.getElementById('editFormContainer').offsetTop, behavior: 'smooth' });
    }

    function closeEditForm() {
        document.getElementById('editFormContainer').style.display = 'none';
    }
</script>