@page
@model WebApplication1.Pages.AddCountryModel
@{
    ViewData["Title"] = "Добавление страны";
}

<h2>Список стран в базе</h2>
<table class="table table-striped table-bordered w-50">
    <thead><tr><th>Название страны</th></tr></thead>
    <tbody>
        @foreach (var con in Model.Countries)
        {
            <tr><td>@con.Name</td></tr>
        }
    </tbody>
</table>

<form method="post" class="mt-4 border p-3 bg-light rounded w-50">
    <div class="form-group mb-3">
        <label for="Name" class="form-label fw-bold">Название новой страны:</label>
        <input type="text" id="Name" name="Name" class="form-control" required />
    </div>
    <button type="submit" class="btn btn-primary">Добавить страну</button>
</form>
<a class="btn btn-secondary mt-3" href="./Index">Назад на главную</a>