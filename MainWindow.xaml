<Window x:Class="lab30_31.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Информационная система ВУЗа (упрощенная)"
        Height="600" Width="1000">
    <DockPanel>
        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="5">
            <Button Content="Сохранить базу" Width="130" Margin="5"
                    Click="SaveButton_Click"/>
            <Button Content="Удалить строку" Width="130" Margin="5"
                    Click="DeleteButton_Click"/>
            <Button Content="Отчет Excel" Width="130" Margin="5"
                    Click="ExcelButton_Click"/>
            <Button Content="Отчет Word" Width="130" Margin="5"
                    Click="WordButton_Click"/>
        </StackPanel>

        <TabControl x:Name="MainTabControl" Margin="5">

            <TabItem Header="Факультеты">
                <DataGrid x:Name="FacultiesGrid"
                          ItemsSource="{Binding FacultiesCollection}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Название факультета" Binding="{Binding FacultyName}" Width="*"/>
                        <DataGridTextColumn Header="ФИО декана" Binding="{Binding DeanFullName}" Width="*"/>
                        <DataGridTextColumn Header="Комната" Binding="{Binding RoomNumber}" Width="80"/>
                        <DataGridTextColumn Header="Корпус" Binding="{Binding BuildingNumber}" Width="80"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Кафедры">
                <DataGrid x:Name="DepartmentsGrid"
                          ItemsSource="{Binding DepartmentsCollection}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="60"/>
                        <DataGridTextColumn Header="Название кафедры" Binding="{Binding DepartmentName}" Width="*"/>
                        <DataGridTextColumn Header="Заведующий" Binding="{Binding HeadName}" Width="*"/>
                        <DataGridTextColumn Header="Комната" Binding="{Binding RoomNumber}" Width="80"/>
                        <DataGridTextColumn Header="Корпус" Binding="{Binding BuildingNumber}" Width="80"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                        <DataGridTextColumn Header="Кол-во преподавателей" Binding="{Binding TeachersCount}" Width="120"/>

                        <DataGridComboBoxColumn Header="Факультет" 
                                                SelectedValueBinding="{Binding FacultyName, UpdateSourceTrigger=PropertyChanged}" 
                                                SelectedValuePath="FacultyName" 
                                                DisplayMemberPath="FacultyName"
                                                Width="180">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.FacultiesCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.FacultiesCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Преподаватели">
                <DataGrid x:Name="TeachersGrid"
                          ItemsSource="{Binding TeachersCollection}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="*"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="*"/>
                        <DataGridTextColumn Header="Отчество" Binding="{Binding MiddleName}" Width="*"/>
                        <DataGridTextColumn Header="Год рождения" Binding="{Binding BirthYear}" Width="90"/>
                        <DataGridTextColumn Header="Год поступления" Binding="{Binding StartYear}" Width="100"/>
                        <DataGridTextColumn Header="Стаж" Binding="{Binding Experience}" Width="70"/>
                        <DataGridTextColumn Header="Должность" Binding="{Binding Position}" Width="*"/>
                        <DataGridTextColumn Header="Пол" Binding="{Binding Gender}" Width="70"/>
                        <DataGridTextColumn Header="Город" Binding="{Binding City}" Width="*"/>

                        <DataGridComboBoxColumn Header="Кафедра" 
                                                SelectedValueBinding="{Binding DepartmentId, UpdateSourceTrigger=PropertyChanged}" 
                                                SelectedValuePath="Id" 
                                                DisplayMemberPath="DepartmentName"
                                                Width="180">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.DepartmentsCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.DepartmentsCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Дисциплины">
                <DataGrid x:Name="DisciplinesGrid"
                          ItemsSource="{Binding DisciplinesCollection}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="60"/>
                        <DataGridTextColumn Header="Название дисциплины" Binding="{Binding DisciplineName}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во часов" Binding="{Binding HoursCount}" Width="100"/>
                        <DataGridTextColumn Header="Цикл" Binding="{Binding Cycle}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Учебная нагрузка">
                <DataGrid x:Name="WorkloadsGrid"
                          ItemsSource="{Binding WorkloadsCollection}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="True"
                          CanUserDeleteRows="True"
                          Margin="5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" IsReadOnly="True" Width="60"/>

                        <DataGridComboBoxColumn Header="Преподаватель" 
                                                SelectedValueBinding="{Binding TeacherId, UpdateSourceTrigger=PropertyChanged}" 
                                                SelectedValuePath="Id" 
                                                DisplayMemberPath="FullName"
                                                Width="180">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.TeachersCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.TeachersCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>

                        <DataGridComboBoxColumn Header="Дисциплина" 
                                                SelectedValueBinding="{Binding DisciplineId, UpdateSourceTrigger=PropertyChanged}" 
                                                SelectedValuePath="Id" 
                                                DisplayMemberPath="DisciplineName"
                                                Width="180">
                            <DataGridComboBoxColumn.ElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.DisciplinesCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.ElementStyle>
                            <DataGridComboBoxColumn.EditingElementStyle>
                                <Style TargetType="ComboBox">
                                    <Setter Property="ItemsSource" Value="{Binding DataContext.DisciplinesCollection, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                </Style>
                            </DataGridComboBoxColumn.EditingElementStyle>
                        </DataGridComboBoxColumn>

                        <DataGridTextColumn Header="Учебный год" Binding="{Binding AcademicYear}" Width="100"/>
                        <DataGridTextColumn Header="Семестр" Binding="{Binding Semester}" Width="80"/>
                        <DataGridTextColumn Header="Группы" Binding="{Binding Groups}" Width="*"/>
                        <DataGridTextColumn Header="Кол-во студентов" Binding="{Binding StudentCount}" Width="120"/>
                        <DataGridTextColumn Header="Вид контроля" Binding="{Binding ControlType}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

        </TabControl>

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem Content="Система готова к работе."/>
        </StatusBar>
    </DockPanel>
</Window>